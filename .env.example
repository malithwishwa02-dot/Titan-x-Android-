# Titan V11.3 — Environment Configuration
# Copy to .env and fill in values

# API Authentication
TITAN_API_SECRET=change-me-to-a-secure-random-string

# Data paths
TITAN_DATA=/opt/titan/data

# GPU / AI
TITAN_GPU_URL=http://127.0.0.1:8765
TITAN_GPU_OLLAMA=http://127.0.0.1:11435

# VMOS Cloud (optional)
VMOS_API_KEY=
VMOS_API_SECRET=

# Hostinger VPS API (optional — for format_vps.py)
HOSTINGER_API_TOKEN=

# Vast.ai GPU tunnel (optional)
VASTAI_HOST=185.62.108.226
VASTAI_PORT=42655
